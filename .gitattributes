# XLIFF translation files
*.xlf text eol=lf linguist-language=XML
*.xml text eol=lf

# Ensure consistent line endings
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Export-ignore: exclude dev files from TER/composer archives
/.devcontainer      export-ignore
/.ddev              export-ignore
/.editorconfig      export-ignore
/.envrc             export-ignore
/.github            export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.husky             export-ignore
/Build              export-ignore
/Tests              export-ignore
/AGENTS.md          export-ignore
/CHANGELOG.md       export-ignore
/CODE_OF_CONDUCT.md export-ignore
/CONTRIBUTING.md    export-ignore
/Contributors.md    export-ignore
/SECURITY.md        export-ignore
/captainhook.json   export-ignore
/codecov.yml        export-ignore
/commitlint.config.js export-ignore
/composer.json.testing export-ignore
/composer.lock      export-ignore
/crowdin.yml        export-ignore
/infection.json5    export-ignore
/package.json       export-ignore
/package-lock.json  export-ignore
/phpunit.xml        export-ignore
/renovate.json      export-ignore
/vex.json           export-ignore
