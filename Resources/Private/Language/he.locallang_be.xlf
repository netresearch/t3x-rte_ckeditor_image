<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" datatype="plaintext" product-name="rte_ckeditor_image" target-language="he">
    <header/>
    <body>
      <trans-unit id="labels.ckeditor.cssclass" xml:space="preserve" approved="yes">
				<source>Custom CSS class</source>
			<target state="final">מחלקת CSS מותאמת</target></trans-unit>
      <trans-unit id="labels.ckeditor.width" xml:space="preserve" approved="yes">
				<source>Width</source>
			<target state="final">רוחב</target></trans-unit>
      <trans-unit id="labels.ckeditor.height" xml:space="preserve" approved="yes">
				<source>Height</source>
			<target state="final">גובע</target></trans-unit>
      <trans-unit id="labels.ckeditor.title" xml:space="preserve" approved="yes">
				<source>Advisory Title</source>
				
			<target state="final">כותרת ייעוצית</target><note>Refers to the HTML title attribute (tooltip on hover). Standard CKEditor/web terminology.</note></trans-unit>
      <trans-unit id="labels.ckeditor.alt" xml:space="preserve" approved="yes">
				<source>Alternative Text</source>
			<target state="final">תאור תחליפי</target></trans-unit>
      <trans-unit id="labels.ckeditor.clicktoenlarge" xml:space="preserve" approved="yes">
				<source>Click to Enlarge</source>
			<target state="final">לחץ להגדלה</target></trans-unit>
      <trans-unit id="labels.ckeditor.enabled" xml:space="preserve" approved="yes">
				<source>Enabled</source>
				
			<target state="final">פעיל</target><note>State label for a toggle checkbox enabling click-to-enlarge. Use adjective (enabled/activated), not verb.</note></trans-unit>
      <trans-unit id="labels.ckeditor.skipimageprocessing" xml:space="preserve" approved="yes">
				<source>Skip Image Processing</source>
			<target state="final">דלג על עיבוד תמונה</target></trans-unit>
      <trans-unit id="labels.ckeditor.imageproperties" xml:space="preserve" approved="yes">
				<source>Image Properties</source>
			<target state="final">מאפייני תמונה</target></trans-unit>
      <trans-unit id="labels.ckeditor.cancel" xml:space="preserve" approved="yes">
				<source>Cancel</source>
				
			<target state="final">בטל</target><note>Button label to close the image properties dialog without saving.</note></trans-unit>
      <trans-unit id="labels.ckeditor.save" xml:space="preserve" approved="yes">
				<source>Save</source>
				
			<target state="final">שמור</target><note>Button label to apply changes in the image properties dialog.</note></trans-unit>
      <trans-unit id="labels.ckeditor.insertimage" xml:space="preserve" approved="yes">
				<source>Insert image</source>
			<target state="final">הוסף תמונה</target></trans-unit>
      <trans-unit id="labels.ckeditor.editimage" xml:space="preserve">
				<source>Edit image</source>
				
			<target state="translated">ערוך תמונה</target><note>Toolbar button label shown when an existing image is selected for editing.</note></trans-unit>
      <trans-unit id="labels.ckeditor.nodefaultmetadata" xml:space="preserve" approved="yes">
				<source>No default %s available in file metadata. Cannot override empty value.</source>
				
			<target state="final">אין %s ברירת מחדל זמין במטא נתוני הקובץ. לא ניתן לעקוף ערך ריק.</target><note>Warning when file metadata is empty. %s is replaced with the field name (e.g. "title", "alt text"). Preserve the %s placeholder.</note></trans-unit>
      <trans-unit id="labels.ckeditor.zoomhelp" xml:space="preserve" approved="yes">
				<source>Enables click-to-enlarge/lightbox functionality. Default popup configuration is provided automatically. See documentation for custom lightbox library integration.</source>
			<target state="final">מאפשר פונקציונליות לחיצה להגדלה/lightbox. תצורת חלון קופץ ברירת מחדל מסופקת אוטומטית. ראה תיעוד לשילוב ספריית lightbox מותאמת.</target></trans-unit>
      <trans-unit id="labels.ckeditor.noscalehelp" xml:space="preserve" approved="yes">
				<source>Skips image processing and uses the original file. Useful for newsletters, PDFs, maximum resolution displays, and SVG graphics. Configure globally via TypoScript or enable per-image.</source>
			<target state="final">מדלג על עיבוד תמונה ומשתמש בקובץ המקורי. שימושי לניוזלטרים, PDF, תצוגות ברזולוציה מקסימלית וגרפיקת SVG. הגדר גלובלית דרך TypoScript או הפעל לכל תמונה.</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality" xml:space="preserve" approved="yes">
				<source>Image Quality</source>
			<target state="final">איכות תמונה</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.none" xml:space="preserve" approved="yes">
				<source>No Scaling</source>
				
			<target state="final">ללא קנה מידה</target><note>Dropdown option: image will not be resized, uses original dimensions.</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.standard" xml:space="preserve" approved="yes">
				<source>Standard (1.0x)</source>
				
			<target state="final">Standard (1.0x)</target><note>Multilingual term - keep as-is unless your language has a more natural equivalent</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.retina" xml:space="preserve" approved="yes">
				<source>Retina (2.0x)</source>
				
			<target state="final">Retina (2.0x)</target><note>Multilingual term - keep as-is or transliterate if more natural in your language</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.ultra" xml:space="preserve" approved="yes">
				<source>Ultra (3.0x)</source>
				
			<target state="final">Ultra (3.0x)</target><note>Multilingual term - keep as-is unless your language has a more natural equivalent</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.print" xml:space="preserve" approved="yes">
				<source>Print (6.0x)</source>
				
			<target state="final">הדפסה (6.0x)</target><note>Dropdown option for print-quality scaling (noun, not the verb "to print"). Preserve the multiplier in parentheses.</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.low.label" xml:space="preserve" approved="yes">
				<source>Low</source>
				
			<target state="final">נמוכה</target><note>Quality indicator label for below-standard but not poor resolution. Conveys below-average quality.</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.low.tooltip" xml:space="preserve" approved="yes">
				<source>Low quality (%sx) - Image may appear blurry</source>
			<target state="final">איכות נמוכה (%sx) - התמונה עלולה להיראות מטושטשת</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.standard.label" xml:space="preserve" approved="yes">
				<source>Standard</source>
				
			<target state="final">תקן</target><note>Multilingual term - keep as-is unless your language has a more natural equivalent</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.standard.tooltip" xml:space="preserve" approved="yes">
				<source>Standard quality (%sx) - Sharp on basic displays</source>
			<target state="final">איכות סטנדרטית (%sx) - חדה על תצוגות בסיסיות</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.retina.label" xml:space="preserve" approved="yes">
				<source>Retina</source>
				
			<target state="final">Retina</target><note>Multilingual term - keep as-is or transliterate if more natural in your language</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.retina.tooltip" xml:space="preserve" approved="yes">
				<source>Retina quality (%sx) - Optimal for modern displays</source>
			<target state="final">איכות Retina (%sx) - אופטימלית לתצוגות מודרניות</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.ultra.label" xml:space="preserve" approved="yes">
				<source>Ultra</source>
				
			<target state="final">Ultra</target><note>Multilingual term - keep as-is unless your language has a more natural equivalent</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.ultra.tooltip" xml:space="preserve" approved="yes">
				<source>Ultra quality (%sx) - For ultra-high DPI or small print</source>
			<target state="final">איכות Ultra (%sx) - ל-DPI גבוה במיוחד או הדפסה קטנה</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.print.label" xml:space="preserve" approved="yes">
				<source>Print</source>
				
			<target state="final">הדפס</target><note>Short label for print-quality tier. Noun (print quality), not verb (print command).</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.print.tooltip" xml:space="preserve" approved="yes">
				<source>Print quality (%sx) - Suitable for high-quality printing (300 DPI)</source>
			<target state="final">איכות הדפסה (%sx) - מתאימה להדפסה באיכות גבוהה (300 DPI)</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.excessive.label" xml:space="preserve" approved="yes">
				<source>Excessive</source>
				
			<target state="final">מוגזמת</target><note>Warning label for unnecessarily high image resolution. Conveys "too much".</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.excessive.tooltip" xml:space="preserve" approved="yes">
				<source>Excessive resolution (%sx) - Unnecessarily high</source>
			<target state="final">רזולוציה מוגזמת (%sx) - גבוהה שלא לצורך</target></trans-unit>
      <trans-unit id="labels.ckeditor.quality.poor.label" xml:space="preserve">
				<source>Poor</source>
				
			<target state="translated">גרועה</target><note>Quality indicator label when image resolution is below standard (ratio less than 1.0x). Conveys insufficient quality.</note></trans-unit>
      <trans-unit id="labels.ckeditor.quality.poor.tooltip" xml:space="preserve">
				<source>Poor quality (%sx) - Image will appear blurry</source>
			<target state="translated">איכות גרועה (%sx) - התמונה תיראה מטושטשת</target></trans-unit>
      <trans-unit id="labels.ckeditor.qualityerror.zerodimensions" xml:space="preserve">
				<source>Display dimensions cannot be zero.</source>
				
			<target state="translated">מידות התצוגה לא יכולות להיות אפס.</target><note>Error message in quality indicator when width or height is set to zero.</note></trans-unit>
      <trans-unit id="labels.ckeditor.qualityinfo.svg" xml:space="preserve">
				<source>Vector image will not be processed (scales perfectly at any resolution).</source>
				
			<target state="translated">תמונה וקטורית לא תעובד (מותאמת בצורה מושלמת בכל רזולוציה).</target><note>Info message shown for SVG files in the quality indicator.</note></trans-unit>
      <trans-unit id="labels.ckeditor.scaling" xml:space="preserve">
				<source>Scaling</source>
				
			<target state="translated">קנה מידה</target><note>Label for the quality/scaling dropdown in the image properties dialog.</note></trans-unit>
      <trans-unit id="labels.ckeditor.caption" xml:space="preserve">
				<source>Caption</source>
				
			<target state="translated">כיתוב</target><note>Label for the image caption textarea field.</note></trans-unit>
      <trans-unit id="labels.ckeditor.displaywidth" xml:space="preserve">
				<source>Display width in px</source>
				
			<target state="translated">רוחב תצוגה בـ px</target><note>Label for the display width input field. "px" = pixels.</note></trans-unit>
      <trans-unit id="labels.ckeditor.displayheight" xml:space="preserve">
				<source>Display height in px</source>
				
			<target state="translated">גובה תצוגה בـ px</target><note>Label for the display height input field. "px" = pixels.</note></trans-unit>
      <trans-unit id="labels.ckeditor.clickBehavior" xml:space="preserve">
				<source>Click Behavior</source>
				
			<target state="translated">התנהגות בלחיצה</target><note>Section heading: what happens when a frontend user clicks the image.</note></trans-unit>
      <trans-unit id="labels.ckeditor.clickBehaviorNone" xml:space="preserve">
				<source>None - image is not clickable</source>
			<target state="translated">ללא - התמונה אינה ניתנת ללחיצה</target></trans-unit>
      <trans-unit id="labels.ckeditor.clickBehaviorEnlarge" xml:space="preserve">
				<source>Enlarge - opens full-size in lightbox</source>
			<target state="translated">הגדל - פותח בגודל מלא בתיבת אור</target></trans-unit>
      <trans-unit id="labels.ckeditor.clickBehaviorLink" xml:space="preserve">
				<source>Link - opens custom URL</source>
			<target state="translated">קישור - פותח כתובת URL מותאמת אישית</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkUrl" xml:space="preserve">
				<source>Link URL</source>
			<target state="translated">כתובת URL של הקישור</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTarget" xml:space="preserve">
				<source>Link Target</source>
				
			<target state="translated">יעד הקישור</target><note>HTML target attribute for links (_blank, _self, etc.).</note></trans-unit>
      <trans-unit id="labels.ckeditor.linkTitle" xml:space="preserve">
				<source>Link Title</source>
			<target state="translated">כותרת הקישור</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkCssClass" xml:space="preserve">
				<source>Link CSS Class</source>
			<target state="translated">מחלקת CSS של הקישור</target></trans-unit>
      <trans-unit id="labels.ckeditor.browse" xml:space="preserve">
				<source>Browse...</source>
				
			<target state="translated">עיון...</target><note>Button to open the file browser for selecting an image or link target. Keep the trailing ellipsis.</note></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetDefault" xml:space="preserve">
				<source>(default)</source>
			<target state="translated">(ברירת מחדל)</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetBlank" xml:space="preserve">
				<source>New window (_blank)</source>
			<target state="translated">חלון חדש (_blank)</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetTop" xml:space="preserve">
				<source>Top frame (_top)</source>
			<target state="translated">מסגרת עליונה (_top)</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetSelf" xml:space="preserve">
				<source>Same window (_self)</source>
			<target state="translated">אותו חלון (_self)</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetParent" xml:space="preserve">
				<source>Parent frame (_parent)</source>
			<target state="translated">מסגרת הורה (_parent)</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkParams" xml:space="preserve">
				<source>Additional Parameters</source>
			<target state="translated">פרמטרים נוספים</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkParamsPlaceholder" xml:space="preserve">
				<source>e.g., &amp;L=1&amp;type=123</source>
			<target state="translated">לדוגמה: &amp;L=1&amp;type=123</target></trans-unit>
      <trans-unit id="labels.ckeditor.linkTargetPlaceholder" xml:space="preserve">
				<source>e.g. _blank, _top, nav_frame</source>
				
			<target state="translated">לדוגמה: _blank, _top, nav_frame</target><note>Placeholder text in the link target input field showing example values.</note></trans-unit>
      <trans-unit id="labels.ckeditor.imageinsidelinktitle" xml:space="preserve">
				<source>Image is inside a link</source>
				
			<target state="translated">התמונה נמצאת בתוך קישור</target><note>Info box title shown when the image is wrapped in a link element in the editor.</note></trans-unit>
      <trans-unit id="labels.ckeditor.imageinsidelinkmessage" xml:space="preserve">
				<source>Click behavior options are disabled because this image is inside a link that was created around the text. To change link settings, edit the link directly in the editor.</source>
				
			<target state="translated">אפשרויות התנהגות הלחיצה מושבתות כי תמונה זו נמצאת בתוך קישור שנוצר סביב הטקסט. לשינוי הגדרות הקישור, ערוך את הקישור ישירות בעורך.</target><note>Info box message explaining why click behavior options are disabled for linked images.</note></trans-unit>
      <trans-unit id="labels.ckeditor.togglecaption" xml:space="preserve">
				<source>Toggle caption</source>
				
			<target state="translated">החלף כיתוב</target><note>Toolbar button label to show/hide the image caption.</note></trans-unit>
      <trans-unit id="labels.ckeditor.toggleinlineblock" xml:space="preserve">
				<source>Toggle inline/block</source>
				
			<target state="translated">החלף שורי/בלוק</target><note>Toolbar button label to switch between inline and block image display.</note></trans-unit>
      <trans-unit id="labels.ckeditor.alignleft" xml:space="preserve">
				<source>Align left</source>
				
			<target state="translated">יישור לשמאל</target><note>Toolbar button to align the image to the left.</note></trans-unit>
      <trans-unit id="labels.ckeditor.aligncenter" xml:space="preserve">
				<source>Align center</source>
				
			<target state="translated">יישור למרכז</target><note>Toolbar button to center-align the image.</note></trans-unit>
      <trans-unit id="labels.ckeditor.alignright" xml:space="preserve">
				<source>Align right</source>
				
			<target state="translated">יישור לימין</target><note>Toolbar button to align the image to the right.</note></trans-unit>
      <trans-unit id="labels.ckeditor.inline" xml:space="preserve">
				<source>Inline</source>
				
			<target state="translated">שורי</target><note>Toolbar button label for inline image display mode (flows with text).</note></trans-unit>
      <trans-unit id="labels.ckeditor.block" xml:space="preserve">
				<source>Block</source>
				
			<target state="translated">בלוק</target><note>Toolbar button label for block image display mode (own paragraph).</note></trans-unit>
      <trans-unit id="labels.ckeditor.selectimage" xml:space="preserve">
				<source>Select image</source>
				
			<target state="translated">בחר תמונה</target><note>Title of the modal dialog for browsing and selecting an image file.</note></trans-unit>
      <trans-unit id="labels.ckeditor.imagewidget" xml:space="preserve">
				<source>image widget</source>
				
			<target state="translated">ווידג'ט תמונה</target><note>Accessibility (ARIA) label for the block image widget. Used by screen readers.</note></trans-unit>
      <trans-unit id="labels.ckeditor.inlineimagewidget" xml:space="preserve">
				<source>inline image widget</source>
				
			<target state="translated">ווידג'ט תמונה מוטבעת</target><note>Accessibility (ARIA) label for the inline image widget. Used by screen readers.</note></trans-unit>
      <trans-unit id="labels.ckeditor.imagetoolbar" xml:space="preserve">
				<source>Image toolbar</source>
				
			<target state="translated">סרגל כלים תמונה</target><note>Accessibility (ARIA) label for the image editing toolbar balloon.</note></trans-unit>
      <trans-unit id="labels.ckeditor.enterimagecaption" xml:space="preserve">
				<source>Enter image caption</source>
				
			<target state="translated">הזן כיתוב תמונה</target><note>Placeholder text shown inside an empty image caption field.</note></trans-unit>
    </body>
  </file>
</xliff>
